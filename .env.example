# ============================================================
# Research Agent – Environment Variables
# Copy this file to .env and fill in any optional values.
# ALL fields are optional. The agent works without any keys.
# ============================================================

# Email for CrossRef polite-pool (improves rate limits, no key needed).
# Any valid email works.
CROSSREF_EMAIL=your@email.com

# Optional: Semantic Scholar API key raises rate limit from 1 rps to 100 rps.
# Request free at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# Optional: IEEE Xplore API key enables richer IEEE metadata.
# Register free at: https://developer.ieee.org/
IEEE_API_KEY=

# Optional: Elsevier API key enables Scopus/ScienceDirect search.
# Register free at: https://dev.elsevier.com/
ELSEVIER_API_KEY=

# How many results to request per source (default: 25, max: 100)
RESULTS_PER_SOURCE=25

# Directory to save JSON output files (default: outputs)
OUTPUT_DIR=outputs

# ============================================================
# Neo4j Knowledge Graph
# Default install: bolt://localhost:7687, user: neo4j
# Set NEO4J_PASSWORD to whatever you chose during installation.
# ============================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# ============================================================
# Qdrant Vector Store
# Run with Docker: docker compose up -d qdrant
# Default port: 6333
# ============================================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=manufacturing_research

# ============================================================
# Knowledge Graph settings
# ============================================================
EMBEDDING_MODEL=all-MiniLM-L6-v2
KG_CHUNK_WORDS=400
KG_CHUNK_OVERLAP=50
KB_DIR=knowledge_base
